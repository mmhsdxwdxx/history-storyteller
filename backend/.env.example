# 复制此文件为项目根目录的 .env 文件
# cp backend/.env.example .env

# ============================================
# OpenAI 配置
# URL 需要包含 /v1，代码会追加 /chat/completions
# ============================================
OPENAI_API_URL=https://your-openai-proxy.com/v1
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4

# ============================================
# Anthropic 配置
# URL 不需要 /v1，代码会追加 /messages
# ============================================
ANTHROPIC_API_URL=https://your-anthropic-proxy.com
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================
# Gemini 配置
# URL 不需要额外路径，代码会追加 /v1/models/{model}:generateContent
# ============================================
GEMINI_API_URL=https://your-gemini-proxy.com
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-pro

# ============================================
# 默认 Provider
# 可选值: openai, anthropic, gemini
# ============================================
DEFAULT_PROVIDER=openai
