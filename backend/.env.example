# Database
DATABASE_URL=postgresql://user:password@db:5432/history_storyteller

# AI Providers - 配置你的代理站点
OPENAI_API_URL=https://your-proxy.com/v1
OPENAI_API_KEY=your-key
OPENAI_MODEL=gpt-4

ANTHROPIC_API_URL=https://your-proxy.com
ANTHROPIC_API_KEY=your-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

GEMINI_API_URL=https://your-proxy.com
GEMINI_API_KEY=your-key
GEMINI_MODEL=gemini-pro

# Default provider: openai, anthropic, or gemini
DEFAULT_PROVIDER=anthropic
